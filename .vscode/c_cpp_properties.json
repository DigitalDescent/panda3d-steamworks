{
    "configurations": [
        {
            "name": "Win64",
            "includePath": [
                "${workspaceFolder}/source/native",
                "${workspaceFolder}/thirdparty/steamworks/public",
                "${env:PANDA3D_DIR}/include",
                "${env:PANDA3D_DIR}/python/include"
            ],
            "defines": [
                "_WIN32",
